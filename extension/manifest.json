{
  "manifest_version": 3,
  "name": "DoubtSense AI Tracker",
  "version": "0.1.0",
  "description": "Tracks what a student is studying and updates DoubtSense AI context.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "DoubtSense AI",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
