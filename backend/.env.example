MONGODB_URI=your_mongodb_connection_string_here
JWT_SECRET=replace_this_with_a_long_random_secret
PORT=4000

# ML service (confusion prediction)
ML_SERVICE_URL=http://127.0.0.1:8000/predict

# OpenAI (backend-only)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Gemini (legacy; not used if OpenAI is configured)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-flash-latest

# Example:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/mydb?retryWrites=true&w=majority
